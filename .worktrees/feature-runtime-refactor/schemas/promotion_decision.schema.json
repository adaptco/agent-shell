{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/promotion_decision.schema.json",
  "title": "PromotionDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "decision", "reason", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "decision": { "type": "string", "enum": ["promote", "hold", "quarantine", "rollback"] },
    "reason": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
