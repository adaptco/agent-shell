{
  "name": "web_search",
  "description": "Run a configured web search provider and return structured results.",
  "input_schema": {
    "type": "object",
    "required": [
      "query"
    ],
    "properties": {
      "query": {
        "type": "string"
      },
      "limit": {
        "type": "integer"
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": [
      "query",
      "results"
    ],
    "properties": {
      "query": {
        "type": "string"
      },
      "results": {
        "type": "array",
        "items": {
          "type": "object"
        }
      }
    },
    "additionalProperties": false
  }
}