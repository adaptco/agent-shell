# Deployment Environment Variables
# Copy this to your deployment server as .env and customize

# GitHub Container Registry
REGISTRY_OWNER=<your-github-username-or-org>
REGISTRY_REPO=<your-repo-name>
IMAGE_TAG=latest

# Service Configuration
API_PORT=8000
LOG_LEVEL=info

# Resource Limits (Docker Compose)
# Set these in docker-compose.yml deploy section
CPU_LIMIT=2
CPU_RESERVE=1
MEMORY_LIMIT=2G
MEMORY_RESERVE=1G

# Application-specific settings
# Add your application environment variables below
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
