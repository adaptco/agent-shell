{
  "name": "discover_skills",
  "description": "Discover and index available skills in the local runtime or remote MCP servers.",
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Optional keyword to filter discovered skills."
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "skills": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "path": { "type": "string" }
          }
        }
      },
      "count": { "type": "integer" }
    },
    "required": ["skills", "count"]
  }
}
