{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/candidate_skills_bundle.schema.json",
  "title": "CandidateSkillsBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "candidate_skills_version",
    "base_skills_version",
    "candidate_skill_paths",
    "promoted_skill_ids",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "candidate_skills_version": { "type": "string", "minLength": 1 },
    "base_skills_version": { "type": ["string", "null"] },
    "candidate_skill_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "promoted_skill_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
