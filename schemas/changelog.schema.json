{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/changelog.schema.json",
  "title": "PromotionChangelog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "candidate_registry_version",
    "candidate_skills_version",
    "tool_changes",
    "skill_changes",
    "config_changes",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "candidate_registry_version": { "type": ["string", "null"] },
    "candidate_skills_version": { "type": ["string", "null"] },
    "tool_changes": { "type": "array", "items": { "type": "string" } },
    "skill_changes": { "type": "array", "items": { "type": "string" } },
    "config_changes": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
