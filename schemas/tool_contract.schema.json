{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/tool_contract.schema.json",
  "title": "ToolContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool_name",
    "version",
    "connector_type",
    "description",
    "risk_tier",
    "input_schema",
    "output_schema",
    "allowed_scopes",
    "side_effect_class",
    "idempotent",
    "receipt_required"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "connector_type": {
      "type": "string",
      "enum": [
        "internal",
        "filesystem",
        "http",
        "github",
        "google_drive",
        "notion",
        "clickup",
        "database",
        "queue"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "allowed_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "side_effect_class": {
      "type": "string",
      "enum": ["read_only", "write_internal", "write_external", "execute"]
    },
    "idempotent": {
      "type": "boolean"
    },
    "receipt_required": {
      "type": "boolean"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "default": 30
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts"],
      "properties": {
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
        "backoff_seconds": {"type": "integer", "minimum": 0, "default": 0}
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "scoped_token_ref", "oidc", "service_account_ref"]
        },
        "credential_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": {"type": ["string", "null"]},
        "reviewer": {"type": ["string", "null"]}
      }
    }
  }
}
