{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/active_registry_state.schema.json",
  "title": "ActiveRegistryState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "active_registry_version",
    "active_registry_path",
    "prior_registry_version",
    "prior_registry_path",
    "activated_at",
    "activation_run_id"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "active_registry_version": { "type": ["string", "null"] },
    "active_registry_path": { "type": ["string", "null"] },
    "prior_registry_version": { "type": ["string", "null"] },
    "prior_registry_path": { "type": ["string", "null"] },
    "activated_at": { "type": ["string", "null"], "format": "date-time" },
    "activation_run_id": { "type": ["string", "null"] }
  }
}
