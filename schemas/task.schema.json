{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "task",
    "status",
    "created_at"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "working",
        "done",
        "failed"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "worker_id": {
      "type": "string"
    },
    "parent_task_id": {
      "type": "string"
    },
    "assigned_subagent": {
      "type": "string"
    },
    "result": {
      "type": "object"
    },
    "error": {
      "type": "object"
    }
  },
  "additionalProperties": true
}